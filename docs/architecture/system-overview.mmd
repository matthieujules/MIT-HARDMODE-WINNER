graph TB
    subgraph SENSING["GLOBAL SENSING"]
        global_mic["Global Mic<br/>Room-level microphone"]
        global_cam["Global Camera<br/>Room-level camera"]
    end

    subgraph USER["USER"]
        voice["Voice"]
        presence["Presence / behavior"]
    end

    subgraph LAPTOP["LAPTOP CONTROL PLANE"]
        api["FastAPI app<br/>HTTP + WebSocket"]
        router["Deterministic router<br/>simple direct commands"]
        master["Master model<br/>Claude Sonnet 4.6<br/>(reasoning tier)"]
        vision["Centralized vision<br/>Claude Vision"]
        state["State store<br/>data/user.md + devices.json<br/>state.json + event_log.jsonl"]
        voice_pipeline["Voice pipeline<br/>VAD + Whisper<br/>(if global mic on laptop)"]
    end

    subgraph DEVICES["DEVICE LAYER (Raspberry Pis)"]
        subgraph LAMP["Lamp"]
            subgraph lamp_stack["Device Runtime"]
                lamp_direct["Direct command handler<br/>no model, immediate HW"]
                lamp_agent["Agent loop<br/>Qwen via Cerebras/Groq<br/>(fast model tier)"]
            end
            lamp_hw["RGB LED<br/>Servos (pan/tilt/roll/lean)"]
        end

        subgraph MIRROR["Mirror"]
            mirror_cam["Mirror Camera<br/>Face-to-face with user"]
            subgraph mirror_stack["Device Runtime"]
                mirror_direct["Direct command handler<br/>no model, immediate HW"]
                mirror_agent["Agent loop<br/>Qwen via Cerebras/Groq<br/>(fast model tier)"]
            end
            mirror_hw["Tilt servo<br/>Speaker"]
        end

        subgraph RADIO["Radio"]
            subgraph radio_stack["Device Runtime"]
                radio_direct["Direct command handler<br/>no model, immediate HW"]
                radio_agent["Agent loop<br/>Qwen via Cerebras/Groq<br/>(fast model tier)"]
            end
            radio_hw["Speaker"]
        end

        subgraph ROVER["Rover"]
            subgraph rover_stack["Device Runtime"]
                rover_reflex["Reflex layer<br/>stall detection, e-stop"]
                rover_direct["Direct command handler<br/>no model, immediate HW"]
                rover_agent["Agent loop<br/>Qwen via Cerebras/Groq<br/>(fast model tier)"]
            end
            rover_hw["Motors + Encoders"]
        end
    end

    voice --> global_mic
    presence --> global_cam
    presence --> mirror_cam

    global_mic --> voice_pipeline
    voice_pipeline --> api
    global_cam --> api

    mirror_cam --> mirror_stack

    mirror_stack --> api
    lamp_stack --> api
    radio_stack --> api
    rover_stack --> api

    api --> router
    api --> vision
    router -->|"no match"| master

    router -->|"direct command"| api
    vision -->|"vision_result"| master
    vision --> state
    master --> state
    state --> master
    api --> state

    api -->|"command (deterministic)"| lamp_direct
    api -->|"command (deterministic)"| mirror_direct
    api -->|"command (deterministic)"| radio_direct
    api -->|"command (deterministic)"| rover_direct

    api -->|"spawn (NL intent)"| lamp_agent
    api -->|"spawn (NL intent)"| mirror_agent
    api -->|"spawn (NL intent)"| radio_agent
    api -->|"spawn (NL intent)"| rover_agent

    lamp_direct --> lamp_hw
    lamp_agent --> lamp_hw
    mirror_direct --> mirror_hw
    mirror_agent --> mirror_hw
    radio_direct --> radio_hw
    radio_agent --> radio_hw
    rover_reflex --> rover_hw
    rover_direct --> rover_hw
    rover_agent --> rover_hw
